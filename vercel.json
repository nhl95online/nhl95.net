{
  "functions": {
    "api/gazette-cron.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/gazette-cron",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/ticker-news-cron",
      "schedule": "0 16 * * *"
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
